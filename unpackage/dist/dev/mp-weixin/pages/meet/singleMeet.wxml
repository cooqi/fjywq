<view class="page-container"><view wx:if="{{a}}" class="login-box"><view class="login-content"><view class="login-avatar"></view><view class="login-title">登录后查看见面记录</view><button class="login-btn" bindtap="{{b}}">立即登录</button></view></view><view wx:else class="content-box"><view class="type-tabs"><view class="{{['tab-item', c && 'active']}}" bindtap="{{d}}"> 演唱会 </view><view class="{{['tab-item', e && 'active']}}" bindtap="{{f}}"> 音乐节/拼盘 </view></view><view class="search-box"><input class="search-input" placeholder="快速搜索并添加场次..." bindconfirm="{{g}}" value="{{h}}" bindinput="{{i}}"/></view><view class="section-box"><view class="section-title">选择主题</view><view class="theme-grid"><view wx:for="{{j}}" wx:for-item="item" wx:key="d" class="{{['theme-item', item.e && 'selected']}}" bindtap="{{item.f}}"><view class="theme-name">{{item.a}}</view><view class="theme-time">{{item.b}}</view><view wx:if="{{item.c}}" class="check-icon">✓</view></view></view><view class="collapse-btn" bindtap="{{l}}">{{k}}</view></view><view class="section-box"><view class="section-title">选择场馆</view><view class="venue-grid"><view wx:for="{{m}}" wx:for-item="item" wx:key="e" class="{{['venue-item', item.f && 'selected']}}" bindtap="{{item.g}}"><view class="venue-name">{{item.a}}</view><view class="venue-time">{{item.b}}</view><view class="venue-count">{{item.c}} 场演出</view><view wx:if="{{item.d}}" class="check-icon">✓</view></view></view></view><view wx:if="{{n}}" class="section-box"><view class="section-title">已选演出（长按可删除）</view><view wx:for="{{o}}" wx:for-item="item" wx:key="d" class="concert-item" bindlongpress="{{item.e}}"><view class="concert-dot"></view><view class="concert-info"><view class="concert-name">{{item.a}}</view><view class="concert-detail">{{item.b}} - {{item.c}}</view></view></view></view><view wx:if="{{p}}" class="add-btn" bindtap="{{q}}"> 添加此场次 </view><view wx:if="{{r}}" class="section-box"><view class="section-title">我的见面记录</view><view wx:for="{{s}}" wx:for-item="item" wx:key="e" class="record-item"><view class="record-dot"></view><view class="record-info"><view class="record-name">{{item.a}}</view><view class="record-detail">{{item.b}} - {{item.c}}</view></view><view class="delete-btn" bindtap="{{item.d}}">删除</view></view></view></view></view>