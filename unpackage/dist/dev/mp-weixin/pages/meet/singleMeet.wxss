.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #cff8f5 0%, #e6cffc 100%);
}
.login-box {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.login-box .login-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}
.login-box .login-content .login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b9d 0%, #c62828 100%);
  margin: 0 auto 32rpx;
}
.login-box .login-content .login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 48rpx;
}
.login-box .login-content .login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c62828 0%, #d32f2f 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}
.content-box {
  padding: 20rpx 30rpx 40rpx;
}
.type-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.type-tabs .tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}
.type-tabs .tab-item.active {
  background: linear-gradient(135deg, #ff6b9d 0%, #c62828 100%);
  color: #fff;
  font-weight: 500;
}
.search-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.search-box .search-input {
  font-size: 28rpx;
  color: #333;
}
.section-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.section-box .section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 24rpx;
}
.section-box .section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #c62828;
  border-radius: 3rpx;
}
.theme-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.theme-grid .theme-item {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  transition: all 0.3s;
}
.theme-grid .theme-item.selected {
  background: linear-gradient(135deg, #fff0f3 0%, #ffe0e6 100%);
  border: 2rpx solid #c62828;
}
.theme-grid .theme-item .theme-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}
.theme-grid .theme-item .theme-time {
  font-size: 22rpx;
  color: #999;
}
.theme-grid .theme-item .check-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #c62828;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.collapse-btn {
  text-align: center;
  padding: 20rpx;
  color: #c62828;
  font-size: 26rpx;
}
.venue-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.venue-grid .venue-item {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  transition: all 0.3s;
}
.venue-grid .venue-item.selected {
  background: linear-gradient(135deg, #fff0f3 0%, #ffe0e6 100%);
  border: 2rpx solid #c62828;
}
.venue-grid .venue-item .venue-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.venue-grid .venue-item .venue-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}
.venue-grid .venue-item .venue-count {
  font-size: 22rpx;
  color: #c62828;
}
.venue-grid .venue-item .check-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #c62828;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.concert-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.concert-item:last-child {
  border-bottom: none;
}
.concert-item .concert-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c62828;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.concert-item .concert-info {
  flex: 1;
}
.concert-item .concert-info .concert-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}
.concert-item .concert-info .concert-detail {
  font-size: 24rpx;
  color: #999;
}
.add-btn {
  background: linear-gradient(135deg, #c62828 0%, #d32f2f 100%);
  color: #fff;
  border-radius: 44rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(198, 40, 40, 0.3);
}
.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.record-item:last-child {
  border-bottom: none;
}
.record-item .record-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c62828;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.record-item .record-info {
  flex: 1;
}
.record-item .record-info .record-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}
.record-item .record-info .record-detail {
  font-size: 24rpx;
  color: #999;
}
.record-item .delete-btn {
  font-size: 24rpx;
  color: #ff6b6b;
  padding: 8rpx 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 12rpx;
}