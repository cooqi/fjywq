}

/* 底部按钮 */
.action-buttons.data-v-cd824c5a {
  padding: 20px;
}
.action-btn.data-v-cd824c5a {
  background: linear-gradient(135deg, #a78bfa 0%, #7c3aed 100%);
  color: #ffffff;
  border: none;
  border-radius: 25px;
  padding: 14px;
  font-size: 16px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-icon.data-v-cd824c5a {
  margin-right: 8px;
  font-size: 18px;
}
.btn-text.data-v-cd824c5a {
  color: #ffffff;
}
