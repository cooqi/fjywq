
.container.data-v-cd824c5a {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3e8ff 0%, #ffffff 30%, #ffffff 100%);
  padding: 0 0 20px 0;
}

/* 日历区域 */
.calendar-section.data-v-cd824c5a {
  background: linear-gradient(135deg, #c4b5fd 0%, #a78bfa 100%);
  padding: 30px 20px 50px;
  border-radius: 0 0 30px 30px;
  position: relative;
  overflow: hidden;
}
.calendar-header.data-v-cd824c5a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}
.month.data-v-cd824c5a {
  font-size: 24px;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 2px;
}
.expand-btn.data-v-cd824c5a {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 15px;
  cursor: pointer;
}
.expand-text.data-v-cd824c5a {
  font-size: 12px;
  color: #ffffff;
  margin-right: 4px;
}
.expand-icon.data-v-cd824c5a {
  font-size: 14px;
  color: #ffffff;
}
.calendar-body.data-v-cd824c5a {
  transition: max-height 0.3s ease;
  overflow: hidden;
}
.calendar-body.data-v-cd824c5a:not(.expanded) {
  max-height: 120px;
}
.calendar-body.expanded.data-v-cd824c5a {
  max-height: 400px;
}
.calendar-days.data-v-cd824c5a {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
  margin-bottom: 10px;
}
.day-label.data-v-cd824c5a {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
}
.calendar-dates.data-v-cd824c5a {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
}
.date-item.data-v-cd824c5a {
  width: 100%;
  text-align: center;
  padding: 8px 0;
  position: relative;
  box-sizing: border-box;
}
.date-number.data-v-cd824c5a {
  font-size: 14px;
  color: #ffffff;
}
.date-item.today .date-number.data-v-cd824c5a {
  background: #ffffff;
  color: #a78bfa;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}
.event-dot.data-v-cd824c5a {
  width: 4px;
  height: 4px;
  background: #ffffff;
  border-radius: 50%;
  margin: 2px auto 0;
}

/* 波浪装饰 */
.wave-decoration.data-v-cd824c5a {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 30px;
  background: linear-gradient(180deg, #f3e8ff 0%, #ffffff 100%);
  -webkit-clip-path: polygon(
    0% 0%, 
    5% 40%, 
    10% 0%, 
    15% 40%, 
    20% 0%, 
    25% 40%, 
    30% 0%, 
    35% 40%, 
    40% 0%, 
    45% 40%, 
    50% 0%, 
    55% 40%, 
    60% 0%, 
    65% 40%, 
    70% 0%, 
    75% 40%, 
    80% 0%, 
    85% 40%, 
    90% 0%, 
    95% 40%, 
    100% 0%, 
    100% 100%, 
    0% 100%
  );
          clip-path: polygon(
    0% 0%, 
    5% 40%, 
    10% 0%, 
    15% 40%, 
    20% 0%, 
    25% 40%, 
    30% 0%, 
    35% 40%, 
