.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #8bf5ee 0%, #b075e7 100%);
  padding: 20rpx;
}
.search-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.search-section .search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.search-section .search-input-wrapper .search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 12rpx;
}
.search-section .search-input-wrapper .clear-btn {
  padding: 8rpx;
}
.search-section .date-picker-wrapper {
  margin-bottom: 20rpx;
}
.search-section .search-btn {
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
  color: #fff;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}
.search-section .search-btn:active {
  opacity: 0.8;
}
.result-section .loading, .result-section .empty-result, .result-section .empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #fff;
  font-size: 28rpx;
}
.result-section .result-list .result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}
.result-section .result-list .result-card .card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.result-section .result-list .result-card .card-header .date {
  font-size: 26rpx;
  color: #8b5cf6;
  font-weight: 600;
}
.result-section .result-list .result-card .card-header .distance {
  font-size: 24rpx;
  color: #eff179;
}
.result-section .result-list .result-card .card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.result-section .result-list .result-card .card-bz {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}
.result-section .result-list .result-card .card-images {
  display: flex;
  flex-wrap: wrap;
}
.result-section .result-list .result-card .card-images .img {
  width: 100rpx;
  height: 100rpx;
  margin: 8rpx;
  border-radius: 8rpx;
}