.about-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #cff8f5 0%, #e6cffc 100%);
  padding-bottom: 40rpx;
}
.logo-section {
  text-align: center;
  padding: 80rpx 40rpx 60rpx;
}
.logo-section .app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}
.logo-section .app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #c62828;
  margin-bottom: 12rpx;
}
.logo-section .app-version {
  font-size: 24rpx;
  color: #999;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 50rpx;
}
.section-title::before {
  content: "";
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #c62828;
  border-radius: 3rpx;
}
.intro-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.intro-section .intro-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}
.db-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.db-section .thanks-box {
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.db-section .thanks-box .thanks-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}
.db-section .thanks-box .thanks-list .thanks-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  text-align: center;
}
.db-section .info-block {
  margin-bottom: 24rpx;
}
.db-section .info-block:last-child {
  margin-bottom: 0;
}
.db-section .info-block .block-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.db-section .info-block .block-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}
.db-section .info-block .block-content .mt-20 {
  display: block;
  margin-top: 20rpx;
}
.contact-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.contact-section .contact-info .contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}
.contact-section .contact-info .contact-item .contact-label {
  font-size: 28rpx;
  color: #666;
}
.contact-section .contact-info .contact-item .contact-value {
  font-size: 28rpx;
  color: #c62828;
  font-weight: 500;
}
.footer {
  text-align: center;
  padding: 40rpx 30rpx;
}
.footer .copyright {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.footer .slogan {
  font-size: 26rpx;
  color: #c62828;
  font-style: italic;
}