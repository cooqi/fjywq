.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #cff8f5 0%, #e6cffc 100%);
  padding-bottom: 40rpx;
}
.action-box {
  padding: 20rpx 30rpx;
}
.action-box .add-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(33, 150, 243, 0.3);
}
.filter-box {
  background: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.filter-box .filter-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.filter-box .filter-item text {
  font-size: 28rpx;
  color: #666;
}
.filter-box .filter-item .picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.filter-box .search-box {
  display: flex;
  align-items: center;
}
.filter-box .search-box .search-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx 0 0 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.filter-box .search-box .search-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: #fff;
  border-radius: 0 12rpx 12rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.list-box {
  padding: 0 30rpx;
}
.list-box .list-header {
  margin-bottom: 20rpx;
}
.list-box .list-header .count {
  font-size: 26rpx;
  color: #999;
}
.list-box .concert-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.list-box .concert-item .item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-box .concert-item .item-header .item-type {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.list-box .concert-item .item-header .item-type.type-concert {
  background: #ffe0e6;
  color: #c62828;
}
.list-box .concert-item .item-header .item-type.type-festival {
  background: #e8f5e9;
  color: #2e7d32;
}
.list-box .concert-item .item-header .item-type.type-other {
  background: #fff3e0;
  color: #e65100;
}
.list-box .concert-item .item-header .item-actions {
  display: flex;
  gap: 16rpx;
}
.list-box .concert-item .item-header .item-actions .action-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}
.list-box .concert-item .item-header .item-actions .action-btn.edit {
  background: #e3f2fd;
  color: #1976D2;
}
.list-box .concert-item .item-header .item-actions .action-btn.delete {
  background: #ffebee;
  color: #c62828;
}
.list-box .concert-item .item-content .item-row {
  display: flex;
  margin-bottom: 12rpx;
}
.list-box .concert-item .item-content .item-row:last-child {
  margin-bottom: 0;
}
.list-box .concert-item .item-content .item-row .label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}
.list-box .concert-item .item-content .item-row .value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}
.list-box .empty-box {
  text-align: center;
  padding: 100rpx 0;
}
.list-box .empty-box .empty-text {
  font-size: 28rpx;
  color: #999;
}
.list-box .load-more {
  text-align: center;
  padding: 30rpx 0;
}
.list-box .load-more text {
  font-size: 28rpx;
  color: #2196F3;
}
.dialog-box {
  background: #fff;
  border-radius: 24rpx;
  width: 680rpx;
  max-height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.dialog-box .dialog-title {
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}
.dialog-box .form-box {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}
.dialog-box .form-box .form-item {
  margin-bottom: 24rpx;
}
.dialog-box .form-box .form-item .form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.dialog-box .form-box .form-item .form-label .required {
  color: #c62828;
}
.dialog-box .form-box .form-item .form-picker {
  height: 72rpx;
  line-height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}
.dialog-box .form-box .form-item .form-input {
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.dialog-box .form-box .form-item .form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  min-height: 150rpx;
}
.dialog-box .dialog-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}
.dialog-box .dialog-actions button {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 0;
  font-size: 30rpx;
}
.dialog-box .dialog-actions .cancel-btn {
  background: #f5f5f5;
  color: #666;
}
.dialog-box .dialog-actions .submit-btn {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: #fff;
}