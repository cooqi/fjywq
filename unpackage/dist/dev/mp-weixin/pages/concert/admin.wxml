<view class="page-container"><view class="action-box"><button class="add-btn" bindtap="{{a}}">+ 添加演唱会/音乐节</button></view><view class="filter-box"><view class="filter-item"><text>类型：</text><picker bindchange="{{c}}" value="{{d}}" range="{{e}}" range-key="label"><view class="picker">{{b}}</view></picker></view><view class="search-box"><input class="search-input" placeholder="搜索主题/场馆/地址" bindconfirm="{{f}}" value="{{g}}" bindinput="{{h}}"/><view class="search-btn" bindtap="{{i}}">搜索</view></view></view><view class="list-box"><view class="list-header"><text class="count">共 {{j}} 条记录</text></view><view wx:for="{{k}}" wx:for-item="item" wx:key="n" class="concert-item"><view class="item-header"><view class="{{['item-type', item.b]}}">{{item.a}}</view><view class="item-actions"><view class="action-btn edit" bindtap="{{item.c}}">编辑</view><view class="action-btn delete" bindtap="{{item.d}}">删除</view></view></view><view class="item-content"><view class="item-row"><text class="label">主题：</text><text class="value">{{item.e}}</text></view><view class="item-row"><text class="label">场馆：</text><text class="value">{{item.f}}</text></view><view class="item-row"><text class="label">场次：</text><text class="value">{{item.g}}</text></view><view class="item-row"><text class="label">时间：</text><text class="value">{{item.h}}</text></view><view class="item-row"><text class="label">地址：</text><text class="value">{{item.i}}</text></view><view wx:if="{{item.j}}" class="item-row"><text class="label">歌单：</text><text class="value">{{item.k}}</text></view><view wx:if="{{item.l}}" class="item-row"><text class="label">备注：</text><text class="value">{{item.m}}</text></view></view></view><view wx:if="{{l}}" class="empty-box"><text class="empty-text">暂无数据</text></view><view wx:if="{{m}}" class="load-more"><text bindtap="{{n}}">加载更多</text></view></view><uni-popup wx:if="{{P}}" class="r" u-s="{{['d']}}" u-r="popup" u-i="6fbbadc0-0" bind:__l="__l" u-p="{{P}}"><view class="dialog-box"><view class="dialog-title">{{o}}演唱会/音乐节</view><view class="form-box"><view class="form-item"><text class="form-label">类型 <text class="required">*</text></text><picker bindchange="{{q}}" value="{{r}}" range="{{s}}" range-key="label"><view class="form-picker">{{p}}</view></picker></view><view class="form-item"><text class="form-label">主题</text><input class="form-input" placeholder="请输入演唱会主题" value="{{t}}" bindinput="{{v}}"/></view><view class="form-item"><text class="form-label">场馆</text><input class="form-input" placeholder="请输入演唱会场馆" value="{{w}}" bindinput="{{x}}"/></view><view class="form-item"><text class="form-label">场次</text><input class="form-input" placeholder="例如：D1、D2" value="{{y}}" bindinput="{{z}}"/></view><view class="form-item"><text class="form-label">时间</text><uni-datetime-picker wx:if="{{B}}" u-i="6fbbadc0-1,6fbbadc0-0" bind:__l="__l" bindupdateModelValue="{{A}}" u-p="{{B}}"/></view><view class="form-item"><text class="form-label">省份 <text class="required">*</text></text><picker bindchange="{{D}}" value="{{E}}" range="{{F}}"><view class="form-picker">{{C}}</view></picker></view><view class="form-item"><text class="form-label">详细地址</text><input class="form-input" placeholder="请输入详细地址" value="{{G}}" bindinput="{{H}}"/></view><view class="form-item"><text class="form-label">歌单</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="请输入歌单内容" value="{{I}}" bindinput="{{J}}"/></block></view><view class="form-item"><text class="form-label">备注</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="请输入备注信息" value="{{K}}" bindinput="{{L}}"/></block></view></view><view class="dialog-actions"><button class="cancel-btn" bindtap="{{M}}">取消</button><button class="submit-btn" bindtap="{{N}}">保存</button></view></view></uni-popup></view>