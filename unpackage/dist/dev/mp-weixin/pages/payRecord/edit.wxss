.content-box {
  padding: 20rpx 30rpx 120rpx;
  background: linear-gradient(180deg, #cff8f5 0%, #e6cffc 100%);
  min-height: 100vh;
}
.section-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.section-box .section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.section-box .section-title .optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}
.section-box .section-title .required {
  font-size: 24rpx;
  color: #8433ee;
  font-weight: normal;
}
.type-scroll {
  white-space: nowrap;
}
.type-scroll .type-item {
  display: inline-block;
  width: 120rpx;
  text-align: center;
  padding: 20rpx 10rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.type-scroll .type-item.active {
  background: linear-gradient(135deg, #66baea 0%, #a97bd6 100%);
  color: #fff;
}
.type-scroll .type-item.active .type-name {
  color: #fff;
}
.type-scroll .type-item.disabled {
  opacity: 0.6;
  pointer-events: none;
}
.type-scroll .type-item .type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.type-scroll .type-item .type-name {
  font-size: 24rpx;
  color: #666;
}
.input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.form-picker {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  color: #333;
}
.concert-info {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff8e1;
  border-radius: 12rpx;
}
.concert-info .info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ffe0b2;
}
.concert-info .info-row:last-child {
  border-bottom: none;
}
.concert-info .info-row .info-label {
  font-size: 26rpx;
  color: #666;
  min-width: 100rpx;
}
.concert-info .info-row .info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  text-align: right;
}
.entry-section {
  margin-top: 20rpx;
}
.entry-section .section-subtitle {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.entry-section .section-subtitle .required {
  font-size: 24rpx;
  color: #0ff8ec;
  font-weight: normal;
}
.entry-section .radio-group {
  display: flex;
  gap: 20rpx;
}
.entry-section .radio-group .radio-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.3s;
}
.entry-section .radio-group .radio-item.active {
  background: linear-gradient(135deg, #66baea 0%, #a97bd6 100%);
  color: #fff;
}
.entry-section .radio-group .radio-item.active .radio-circle {
  border-color: #fff;
}
.entry-section .radio-group .radio-item.active .radio-circle::after {
  background: #fff;
}
.entry-section .radio-group .radio-item .radio-circle {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  margin-right: 12rpx;
  position: relative;
  transition: all 0.3s;
}
.entry-section .radio-group .radio-item .radio-circle::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.3s;
}
.entry-section .radio-group .radio-item text {
  font-size: 28rpx;
  color: inherit;
}
.form-item {
  margin-top: 20rpx;
}
.form-item .section-subtitle {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.form-item .section-subtitle .optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}
.amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.amount-item:last-child {
  border-bottom: none;
}
.amount-item .amount-label {
  font-size: 28rpx;
  color: #333;
}
.amount-item .amount-label .optional {
  font-size: 24rpx;
  color: #999;
}
.amount-item .amount-input {
  width: 300rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  text-align: right;
}
.amount-item.total {
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}
.amount-item.total .total-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #844eb1;
}
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}
.upload-box {
  display: flex;
  flex-wrap: wrap;
}
.upload-box .upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.upload-box .upload-item .upload-image {
  width: 100%;
  height: 100%;
}
.upload-box .upload-item .upload-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 32rpx;
  line-height: 40rpx;
  text-align: center;
}
.upload-box .upload-add {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 2rpx dashed #ddd;
}
.upload-box .upload-add .upload-add-icon {
  font-size: 48rpx;
  color: #999;
}
.upload-box .upload-add .upload-add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.upload-box .upload-add .upload-add-count {
  font-size: 20rpx;
  color: #bbb;
}
.textarea {
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
.btn-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 9999;
}
.btn-box .btn-save {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #66baea 0%, #a97bd6 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}
.btn-box .btn-delete {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #c62828;
  border: 2rpx solid #c62828;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 16rpx;
}