<view class="content-box"><view class="stats-box"><view class="stats-item"><view class="stats-label">总消费</view><view class="stats-value">¥{{a}}</view></view><view class="stats-item"><view class="stats-label">记录数</view><view class="stats-value">{{b}}条</view></view></view><view class="filter-box"><scroll-view class="filter-scroll" scroll-x><view wx:for="{{c}}" wx:for-item="item" wx:key="c" class="{{['filter-item', item.b && 'active']}}" bindtap="{{item.d}}">{{item.a}}</view></scroll-view></view><view class="record-list"><view wx:for="{{d}}" wx:for-item="item" wx:key="i" class="record-item" bindtap="{{item.j}}"><view class="record-header"><view class="record-type">{{item.a}}</view><view class="record-amount">¥{{item.b}}</view></view><view class="record-name">{{item.c}}</view><view class="record-info"><view class="record-time">{{item.d}}</view><view wx:if="{{item.e}}" class="record-detail">数量：{{item.f}}</view></view><view wx:if="{{item.g}}" class="record-detail">备注：{{item.h}}</view></view></view><view wx:if="{{e}}" class="tips">暂无消费记录</view><view class="add-btn" bindtap="{{f}}">+</view></view>