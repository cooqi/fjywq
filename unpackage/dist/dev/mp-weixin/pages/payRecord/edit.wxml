<view class="content-box"><view class="section-box"><view class="section-title">分类</view><scroll-view scroll-x class="type-scroll"><view wx:for="{{a}}" wx:for-item="item" wx:key="d" class="{{['type-item', item.c && 'active', b && 'disabled']}}" bindtap="{{item.e}}"><view class="type-icon">{{item.a}}</view><view class="type-name">{{item.b}}</view></view></scroll-view></view><view wx:if="{{c}}" class="section-box"><view class="section-title">选择场次 <text class="required">*</text></view><picker bindchange="{{e}}" value="{{f}}" range="{{g}}" range-key="displayName"><view class="form-picker">{{d}}</view></picker><view wx:if="{{h}}" class="concert-info"><view wx:if="{{i}}" class="info-row"><text class="info-label">主题：</text><text class="info-value">{{j}}</text></view><view wx:if="{{k}}" class="info-row"><text class="info-label">场次：</text><text class="info-value">{{l}}</text></view><view wx:if="{{m}}" class="info-row"><text class="info-label">场馆：</text><text class="info-value">{{n}}</text></view><view class="info-row"><text class="info-label">时间：</text><text class="info-value">{{o}}</text></view><view class="info-row"><text class="info-label">地址：</text><text class="info-value">{{p}}</text></view></view><view class="entry-section"><view class="section-subtitle">是否有票入场 <text class="required">*</text></view><view class="radio-group"><view class="{{['radio-item', q && 'active']}}" bindtap="{{r}}"><view class="radio-circle"></view><text>有票</text></view><view class="{{['radio-item', s && 'active']}}" bindtap="{{t}}"><view class="radio-circle"></view><text>外场</text></view></view></view><view wx:if="{{v}}" class="form-item"><view class="section-subtitle">座位号 <text class="optional">选填</text></view><input class="input" placeholder="请输入座位号，如：A区1排5座" value="{{w}}" bindinput="{{x}}"/></view></view><view wx:if="{{y}}" class="section-box"><view class="section-title">名称</view><input class="input" placeholder="{{z}}" value="{{A}}" bindinput="{{B}}"/></view><view class="section-box"><view class="section-title">金额</view><block wx:if="{{C}}"><view class="amount-item"><view class="amount-label">原票价</view><input class="amount-input" type="digit" placeholder="0.00" bindinput="{{D}}" value="{{E}}"/></view><view class="amount-item"><view class="amount-label">数量 </view><input class="amount-input" type="number" placeholder="1" bindinput="{{F}}" value="{{G}}"/></view><view class="amount-item"><view class="amount-label">实付</view><input class="amount-input" type="digit" placeholder="0.00" value="{{H}}" bindinput="{{I}}"/></view><view class="amount-item"><view class="amount-label">交通费 <text class="optional">选填</text></view><input class="amount-input" type="digit" placeholder="0.00" bindinput="{{J}}" value="{{K}}"/></view><view class="amount-item"><view class="amount-label">住宿费 <text class="optional">选填</text></view><input class="amount-input" type="digit" placeholder="0.00" bindinput="{{L}}" value="{{M}}"/></view><view class="amount-item"><view class="amount-label">其他费用 <text class="optional">选填</text></view><input class="amount-input" type="digit" placeholder="0.00" bindinput="{{N}}" value="{{O}}"/></view></block><block wx:else><view class="amount-item"><view class="amount-label">单价 <text class="optional">选填</text></view><input class="amount-input" type="digit" placeholder="0.00" bindinput="{{P}}" value="{{Q}}"/></view><view class="amount-item"><view class="amount-label">数量 <text class="optional">选填</text></view><input class="amount-input" type="number" placeholder="1" bindinput="{{R}}" value="{{S}}"/></view></block><view class="amount-item total"><view class="amount-label">总金额</view><view class="total-amount">¥ {{T}}</view></view></view><view class="section-box"><view class="section-title">购买日期</view><uni-datetime-picker wx:if="{{V}}" u-i="eccb62d4-0" bind:__l="__l" bindupdateModelValue="{{U}}" u-p="{{V}}"/></view><view wx:if="{{W}}" class="section-box"><view class="section-title">演唱会/音乐节主办地址 <text class="optional">已自动填充</text></view><input class="input" placeholder="地址将从选择的场次自动填充" disabled value="{{X}}" bindinput="{{Y}}"/></view><view class="section-box"><view class="section-title">晒单链接 <text class="optional">选填</text></view><block wx:if="{{r0}}"><textarea class="textarea" placeholder="如果你有在其他平台发布一些晒单，可以复制链接记录在这里" maxlength="200" value="{{Z}}" bindinput="{{aa}}"></textarea></block></view><view class="section-box"><view class="section-title">订单截图 <text class="optional">不建议在小程序储存图片，以防丢失</text></view><view class="upload-box"><view wx:for="{{ab}}" wx:for-item="img" wx:key="d" class="upload-item"><image class="upload-image" src="{{img.a}}" mode="aspectFill" bindtap="{{img.b}}"></image><view class="upload-delete" catchtap="{{img.c}}">×</view></view><view wx:if="{{ac}}" class="upload-add" bindtap="{{ae}}"><text class="upload-add-icon">+</text><text class="upload-add-text">添加照片</text><text class="upload-add-count">{{ad}}/1</text></view></view></view><view class="section-box"><view class="section-title">备注 <text class="optional">选填</text></view><block wx:if="{{r0}}"><textarea class="textarea" placeholder="添加备注..." maxlength="200" value="{{af}}" bindinput="{{ag}}"></textarea></block></view><view class="btn-box"><button class="btn-save" bindtap="{{ai}}">{{ah}}</button><button wx:if="{{aj}}" class="btn-delete" bindtap="{{ak}}">删除这条记录</button></view><canvas canvas-id="compressCanvas" style="width:800px;height:800px;position:fixed;left:-9999px;top:-9999px"></canvas></view>