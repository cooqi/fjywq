<view class="page-container"><view wx:if="{{a}}" class="login-tip"><text>请先登录后查看足迹</text></view><view wx:else class="content-box"><view class="stats-box"><view class="stat-item"><view class="stat-value">{{b}}</view><view class="stat-label">去过的省份</view></view><view class="stat-item"><view class="stat-value">{{c}}</view><view class="stat-label">参加场次</view></view></view><view class="province-list"><view class="list-title">足迹详情</view><view wx:for="{{d}}" wx:for-item="province" wx:key="d" class="province-item" bindtap="{{province.e}}"><view class="province-info"><view class="province-name">{{province.a}}</view><view class="province-count">{{province.b}} 场</view></view><view class="province-cities"><text wx:for="{{province.c}}" wx:for-item="city" wx:key="b" class="city-tag">{{city.a}}</text></view></view><view wx:if="{{e}}" class="empty-box"><view class="empty-icon">🗺️</view><text class="empty-text">还没有足迹记录</text><text class="empty-desc">参加演唱会或音乐节后会自动生成足迹</text></view></view></view><view wx:if="{{f}}" class="loading-box"><text>加载中...</text></view></view>