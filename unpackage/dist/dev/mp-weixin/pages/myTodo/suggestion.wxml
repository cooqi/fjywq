<view class="page-container"><block wx:if="{{a}}"><view class="submit-section"><view class="section-title"><uni-icons wx:if="{{b}}" u-i="584940bb-0" bind:__l="__l" u-p="{{b}}"></uni-icons><text>我有话说</text></view><view class="form-box"><block wx:if="{{r0}}"><textarea class="suggestion-textarea" placeholder="请输入..." maxlength="{{1000}}" auto-height value="{{c}}" bindinput="{{d}}"/></block><view class="word-count">{{e}}/1000</view><button class="{{['submit-btn', f && 'is-disabled']}}" bindtap="{{g}}" disabled="{{h}}"> 提交 </button></view></view><view wx:if="{{i}}" class="reply-section"><view class="section-title"><uni-icons wx:if="{{j}}" u-i="584940bb-1" bind:__l="__l" u-p="{{j}}"></uni-icons><text>管理员回复</text></view><view class="reply-list"><view wx:for="{{k}}" wx:for-item="item" wx:key="d" class="reply-card"><view class="reply-header"><text class="reply-time">{{item.a}}</text></view><view class="reply-content"><view class="question-label">我的：</view><view class="question-text">{{item.b}}</view><view class="answer-label">管理员回复：</view><rich-text class="answer-text" nodes="{{item.c}}"></rich-text></view></view></view></view></block><block wx:if="{{l}}"><view class="admin-section"><view class="section-title admin-title"><uni-icons wx:if="{{m}}" u-i="584940bb-2" bind:__l="__l" u-p="{{m}}"></uni-icons><text>管理员工作台 (待处理反馈)</text></view><view wx:if="{{n}}" class="loading"><text>加载中...</text></view><view wx:elif="{{o}}" class="admin-list"><view wx:for="{{p}}" wx:for-item="item" wx:key="g" class="admin-card"><view class="user-question"><view class="q-header"><text class="q-time">{{item.a}}</text></view><text class="q-content">{{item.b}}</text></view><view class="status-selector"><text class="selector-label">处理状态：</text><view class="status-tags"><view wx:for="{{item.c}}" wx:for-item="opt" wx:key="b" class="{{['status-tag', opt.c && 'active']}}" style="{{'border-color:' + opt.d + ';' + ('color:' + opt.e) + ';' + ('background:' + opt.f)}}" bindtap="{{opt.g}}">{{opt.a}}</view></view></view><view class="reply-input-box"><block wx:if="{{r0}}"><textarea class="reply-textarea" value="{{item.d}}" bindinput="{{item.e}}" placeholder="请输入回复内容..." maxlength="500"/></block></view><button class="admin-submit-btn" bindtap="{{item.f}}"> 提交处理 </button></view></view><view wx:else class="empty-reply"><uni-icons wx:if="{{q}}" u-i="584940bb-3" bind:__l="__l" u-p="{{q}}"></uni-icons><text>太棒了，暂无待处理的反馈！</text></view></view></block></view>