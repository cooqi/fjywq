<view class="page-container"><view class="search-box"><text class="search-label">日期搜索</text><input class="search-input" name="date" placeholder="请输入日期" bindblur="{{a}}" value="{{b}}" bindinput="{{c}}"/></view><view class="list-section"><view wx:for="{{d}}" wx:for-item="item" wx:key="c" class="list-item" bindtap="{{item.d}}"><text class="item-date">{{item.a}}</text><text class="item-title">{{item.b}}</text><text class="item-arrow">›</text></view><view wx:if="{{e}}" class="empty-list"><text>暂无数据</text></view></view><view class="form-section"><form><view class="form-item"><text class="form-label">日期</text><input class="form-input" name="date" placeholder="请输入日期（如：2024-1-1）" value="{{f}}" bindinput="{{g}}"/></view><view class="form-item"><text class="form-label">标题</text><input class="form-input" name="title" placeholder="请输入标题" value="{{h}}" bindinput="{{i}}"/></view><view class="form-item"><text class="form-label">备注</text><block wx:if="{{r0}}"><textarea class="form-textarea" name="bz" placeholder="请输入备注" value="{{j}}" bindinput="{{k}}"/></block></view><view class="form-item"><text class="form-label">类型</text><input class="form-input" name="title" placeholder="1重要，2糖" value="{{l}}" bindinput="{{m}}"/></view><view class="form-item"><text class="form-label">图片路径</text><block wx:if="{{r0}}"><textarea class="form-textarea" name="imgurl" placeholder="请输入图片路径，多个用分号隔开" value="{{n}}" bindinput="{{o}}"/></block></view><view wx:if="{{p}}" class="form-actions"><button type="primary" class="action-btn update-btn" bindtap="{{q}}"> 更新 </button><button wx:if="{{r}}" type="primary" class="action-btn delete-btn" bindtap="{{s}}"> 删除 </button><button type="primary" class="action-btn clear-btn" bindtap="{{t}}"> 清空 </button></view><button wx:else type="primary" class="action-btn save-btn full-width" bindtap="{{v}}"> 保存 </button></form></view><view class="greeting-section"><view class="section-title"><text class="title-icon">🔔</text><text>问候语设置</text></view><form><view class="form-item"><text class="form-label">问候语</text><input class="form-input" name="greeting" placeholder="请输入问候语" value="{{w}}" bindinput="{{x}}"/></view><button type="primary" class="action-btn save-btn full-width" bindtap="{{y}}"> 保存问候语 </button></form></view></view>