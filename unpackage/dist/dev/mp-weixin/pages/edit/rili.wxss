.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  padding: 16px;
}
.search-box {
  background: #fff;
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}
.search-box .search-label {
  font-size: 14px;
  color: #666;
  margin-right: 12px;
  white-space: nowrap;
}
.search-box .search-input {
  flex: 1;
  font-size: 15px;
}
.list-section {
  background: #fff;
  border-radius: 12px;
  padding: 8px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.list-section .list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-radius: 8px;
  margin-bottom: 4px;
  background: #fafafa;
  transition: all 0.3s ease;
}
.list-section .list-item:last-child {
  margin-bottom: 0;
}
.list-section .list-item:active {
  background: #f0f0f0;
}
.list-section .list-item .item-date {
  font-size: 13px;
  color: #aaa1ce;
  margin-right: 12px;
  white-space: nowrap;
}
.list-section .list-item .item-title {
  flex: 1;
  font-size: 15px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.list-section .list-item .item-arrow {
  font-size: 20px;
  color: #999;
  margin-left: 8px;
}
.list-section .empty-list {
  text-align: center;
  padding: 30px;
  color: #999;
  font-size: 14px;
}
.form-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.form-section .form-item {
  margin-bottom: 16px;
}
.form-section .form-item:last-child {
  margin-bottom: 0;
}
.form-section .form-item .form-label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  font-weight: 500;
}
.form-section .form-item .form-input {
  width: 100%;
  height: 44px;
  background: #f5f7fa;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
}
.form-section .form-item .form-textarea {
  width: 100%;
  min-height: 80px;
  background: #f5f7fa;
  border-radius: 8px;
  padding: 12px;
  font-size: 15px;
  line-height: 1.5;
}
.form-section .form-actions {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}
.form-section .form-actions .action-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 500;
  border: none;
}
.form-section .form-actions .save-btn {
  background: linear-gradient(135deg, #aaa1ce 0%, #9b8fbf 100%);
  color: #fff;
}
.form-section .form-actions .update-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}
.form-section .form-actions .delete-btn {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  color: #fff;
}
.form-section .form-actions .clear-btn {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  color: #333;
}
.form-section .form-actions .full-width {
  width: 100%;
}
.greeting-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
.greeting-section .section-title {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}
.greeting-section .section-title .title-icon {
  width: 20px;
  height: 20px;
  margin-right: 8px;
}
.greeting-section .section-title text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}
.greeting-section .form-item {
  margin-bottom: 16px;
}
.greeting-section .form-item .form-label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  font-weight: 500;
}
.greeting-section .form-item .form-input {
  width: 100%;
  height: 44px;
  background: #f5f7fa;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
}
.greeting-section .action-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 500;
  border: none;
  background: linear-gradient(135deg, #aaa1ce 0%, #9b8fbf 100%);
  color: #fff;
}
.flex-row {
  display: flex;
}
.title {
  color: cadetblue;
}
.page {
  padding: 5px;
}
.uni-form-item {
  margin-bottom: 10px;
}
.search-box {
  background: #eee;
  margin-bottom: 15px;
  padding: 3px;
}
.list {
  margin-bottom: 20px;
}
.list .list-item {
  background: #ddd;
  margin-bottom: 5px;
  padding: 3px;
}
.customGreeting {
  margin-top: 30px;
}
.customGreeting .customGreeting-save-btn {
  margin: auto;
  text-align: center;
}